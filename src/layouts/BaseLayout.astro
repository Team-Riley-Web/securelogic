---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Secure Logic | Precision Misting and Botanical Disinfection',
  description = 'Secure Logic designs Genesis 360 automated misting systems and BotaniMax botanical disinfectant for precise whole-room environmental coverage.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
