---
import { Mail, Phone } from '@lucide/astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';
---

<footer class="bg-slate-900 text-white">
  <div class="container-page grid gap-10 py-14 md:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
    <div class="max-w-sm">
      <Image src={logo} alt="Secure Logic logo" class="h-20 w-20 rounded-md bg-white object-contain p-1" widths={[120, 180]} sizes="80px" />
      <p class="mt-5 text-sm leading-7 text-slate-300">
        We believe that the path to a cleaner, healthier indoor environment should be rooted in the very essence of nature itself.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-botanical-300">Quick Links</h2>
      <div class="mt-4 grid gap-3 text-sm text-slate-300">
        <a href="/" class="hover:text-white">Home</a>
        <a href="/about-us/" class="hover:text-white">About Us</a>
        <a href="/resources/faqs/" class="hover:text-white">FAQs</a>
        <a href="/contact-us/" class="hover:text-white">Contact Us</a>
      </div>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-botanical-300">Legal</h2>
      <div class="mt-4 grid gap-3 text-sm text-slate-300">
        <a href="/get-a-quote/" class="hover:text-white">Terms & Conditions</a>
        <a href="/privacy-policy/" class="hover:text-white">Privacy Policies</a>
      </div>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-botanical-300">Contact</h2>
      <div class="mt-4 grid gap-3 text-sm text-slate-300">
        <a href="tel:18889974310" class="inline-flex items-center gap-3 hover:text-white"><Phone class="h-4 w-4 text-botanical-300" />1-888-997-4310</a>
        <a href="mailto:info@securelogicUSA.com" class="inline-flex items-center gap-3 hover:text-white"><Mail class="h-4 w-4 text-botanical-300" />info@securelogicUSA.com</a>
      </div>
      <div class="mt-6 flex gap-3">
        <a href="http://facebook.com/SecureLogicUSA" aria-label="Facebook" class="rounded-md bg-white/10 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-white/20">FB</a>
        <a href="https://www.instagram.com/securelogicusa/" aria-label="Instagram" class="rounded-md bg-white/10 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-white/20">IG</a>
        <a href="https://www.youtube.com/@SecureLogic-Genesis360" aria-label="YouTube" class="rounded-md bg-white/10 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-white/20">YT</a>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <p class="container-page text-center text-xs text-slate-400">Copyright 2025 © Secure Logic</p>
  </div>
</footer>
