<script>
  const revealItems = Array.from(document.querySelectorAll('.reveal'));

  if (revealItems.length) {
    document.documentElement.classList.add('reveal-enabled');

    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          });
        },
        { rootMargin: '0px 0px -12% 0px', threshold: 0.08 },
      );

      revealItems.forEach((item) => revealObserver.observe(item));
    } else {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    }
  }

  const heroSlides = Array.from(document.querySelectorAll('[data-hero-slide]'));
  const heroDots = Array.from(document.querySelectorAll('[data-hero-dot]'));
  const typedHeroWord = document.querySelector('[data-typed-hero-word]');
  const heroLabel = document.querySelector('[data-hero-label]');
  const heroTitle = document.querySelector('[data-hero-title]');
  const heroCopy = document.querySelector('[data-hero-copy]');
  const heroContent = [
    { label: 'Agriculture', title: 'Crop fields and greenhouses', copy: 'Dry mist reaches canopy, equipment, and air zones without soaking plants or disrupting production.' },
    { label: 'Controlled Environments', title: 'Cannabis and indoor grow rooms', copy: 'Automated treatment helps reduce microbial pressure where humidity and dense growth raise risk.' },
    { label: 'Built Environments', title: 'Schools and shared facilities', copy: 'Repeatable whole-room cycles support cleaner air and surfaces in high-traffic indoor spaces.' },
  ];
  let heroIndex = 0;
  let heroTimer: number | undefined;

  function selectHero(index: number) {
    heroIndex = index;

    heroSlides.forEach((slide) => {
      const isSelected = slide.getAttribute('data-hero-slide') === String(index);
      slide.classList.toggle('opacity-95', isSelected);
      slide.classList.toggle('opacity-0', !isSelected);
    });

    heroDots.forEach((dot) => {
      const isSelected = dot.getAttribute('data-hero-dot') === String(index);
      dot.classList.toggle('w-8', isSelected);
      dot.classList.toggle('w-2.5', !isSelected);
      dot.classList.toggle('bg-botanical-300', isSelected);
      dot.classList.toggle('bg-white/35', !isSelected);
    });

    const content = heroContent[index];
    if (heroLabel) heroLabel.textContent = content.label;
    if (heroTitle) heroTitle.textContent = content.title;
    if (heroCopy) heroCopy.textContent = content.copy;
  }

  function startHeroCarousel() {
    window.clearInterval(heroTimer);
    heroTimer = window.setInterval(() => {
      selectHero((heroIndex + 1) % heroContent.length);
    }, 5200);
  }

  heroDots.forEach((dot) => {
    dot.addEventListener('click', () => {
      selectHero(Number(dot.getAttribute('data-hero-dot') || 0));
      startHeroCarousel();
    });
  });

  if (heroSlides.length) startHeroCarousel();

  const typedWords = ['Disinfection', 'Clean', 'Health'];
  let typedWordIndex = 0;
  let typedLetterIndex = typedWords[0].length;
  let typedDirection: 'typing' | 'deleting' | 'holding' = 'holding';

  function cycleTypedHeroWord() {
    if (!typedHeroWord) return;

    const currentWord = typedWords[typedWordIndex];
    const setTypedWord = (value: string) => {
      typedHeroWord.textContent = value || '\u00a0';
    };

    if (typedDirection === 'holding') {
      typedDirection = 'deleting';
      window.setTimeout(cycleTypedHeroWord, 900);
      return;
    }

    if (typedDirection === 'deleting') {
      typedLetterIndex -= 1;
      setTypedWord(currentWord.slice(0, typedLetterIndex));

      if (typedLetterIndex <= 0) {
        typedWordIndex = (typedWordIndex + 1) % typedWords.length;
        typedDirection = 'typing';
        window.setTimeout(cycleTypedHeroWord, 180);
        return;
      }

      window.setTimeout(cycleTypedHeroWord, 55);
      return;
    }

    const nextWord = typedWords[typedWordIndex];
    typedLetterIndex += 1;
    setTypedWord(nextWord.slice(0, typedLetterIndex));

    if (typedLetterIndex >= nextWord.length) {
      typedDirection = 'holding';
      window.setTimeout(cycleTypedHeroWord, 1400);
      return;
    }

    window.setTimeout(cycleTypedHeroWord, 92);
  }

  if (typedHeroWord) {
    window.setTimeout(cycleTypedHeroWord, 1400);
  }

  const appTabs = Array.from(document.querySelectorAll('[data-app-tab]'));
  const appPanels = Array.from(document.querySelectorAll('[data-app-panel]'));

  function selectApplication(index: number) {
    appTabs.forEach((tab) => {
      const isSelected = tab.getAttribute('data-app-tab') === String(index);
      tab.setAttribute('aria-selected', String(isSelected));
    });

    appPanels.forEach((panel) => {
      panel.toggleAttribute('hidden', panel.getAttribute('data-app-panel') !== String(index));
    });
  }

  appTabs.forEach((tab) => {
    const activate = () => {
      selectApplication(Number(tab.getAttribute('data-app-tab') || 0));
    };

    tab.addEventListener('mouseenter', activate);
    tab.addEventListener('focus', activate);
    tab.addEventListener('click', activate);
  });

  window.addEventListener('select-app', (event) => {
    const detail = (event as CustomEvent<{ index?: number }>).detail;
    selectApplication(detail?.index || 0);
  });
</script>
