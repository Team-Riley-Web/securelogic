---
import type { ImageMetadata } from 'astro';
import { ArrowLeft, ArrowRight, Check, ChevronRight, Cpu, Droplets, Leaf, Menu, Sparkles, Star, X } from '@lucide/astro';
import { Image } from 'astro:assets';
import CurveDivider from '../components/CurveDivider.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import logo from '../assets/images/logo.png';
import products from '../assets/images/medical.png';
import botanimax from '../assets/images/botanimax-bottle.png';
import greenhouse from '../assets/images/blog-greenhouse.png';
import cannabis from '../assets/images/blog-cannabis.png';
import wrestling from '../assets/images/blog-wrestling.png';
import sickBuilding from '../assets/images/blog-sick-building.png';
import contactBg from '../assets/images/contact-bg.jpeg';
import medicalMist from '../assets/images/medical-mist.png';
import mobileMist from '../assets/images/mobile-mist.png';
import portableMist from '../assets/images/portable-mist.png';
import farmVideo from '../assets/videos/farm.mp4';
import cannabisVideo from '../assets/videos/cannabis.mp4';
import gymVideo from '../assets/videos/gym.mp4';
import cowsVideo from '../assets/videos/cows.mp4';
import farmer1 from '../assets/images/farmer1.png';
import farmer2 from '../assets/images/farmer2.png';
import farmer3 from '../assets/images/farmer3.png';
import farmer4 from '../assets/images/farmer4.png';

const applications = [
  { title: 'Agriculture', copy: 'Engineered 360-degree dry mist for crops, livestock, and controlled-environment agriculture.', uses: ['Cannabis grow rooms', 'Greenhouses and vertical farms', 'Livestock barns and hatcheries'], image: greenhouse, alt: 'Rows of strawberries growing inside a greenhouse' },
  { title: 'Athletic Facilities', copy: 'Targets sweat-prone, high-contact training spaces with consistent 360-degree coverage.', uses: ['Wrestling and martial arts rooms', 'Weight rooms and cardio areas', 'Locker rooms and showers'], image: wrestling, alt: 'Two wrestlers in a gym with illustrated pathogens nearby' },
  { title: 'Early Child Care', copy: 'Helps protect high-touch environments where young children play, learn, and nap.', uses: ['Classrooms and playrooms', 'Nap rooms', 'Shared restrooms and storage'], image: contactBg, alt: 'Bright classroom with desks and daylight' },
  { title: 'Schools', copy: 'Provides automated whole-room treatment across busy K-12 and campus facilities.', uses: ['Classrooms and labs', 'Cafeterias and libraries', 'Buses and transport fleets'], image: sickBuilding, alt: 'Bright shared facility with illustrated airborne germs' },
  { title: 'Medical & Healthcare', copy: 'Supports infection-control goals in clinical, procedural, and long-term care settings.', uses: ['Patient rooms', 'Dialysis clinics', 'Procedure and isolation rooms'], image: medicalMist, alt: 'Medical misting system product' },
  { title: 'Military & Public Safety', copy: 'Delivers portable and fixed-system coverage for mission-critical, high-traffic spaces.', uses: ['Barracks and common rooms', 'Command centers', 'Vehicles and mobile clinics'], image: portableMist, alt: 'Portable misting system product' },
  { title: 'Cruise Ships & Marine Vessels', copy: 'Brings automated misting to complex, multi-deck marine environments.', uses: ['Guest cabins', 'Dining rooms and galleys', 'Medical bays and crew quarters'], image: mobileMist, alt: 'Mobile misting system product' },
  { title: 'Entertainment Venues', copy: 'Supports safer, cleaner environments wherever large crowds gather indoors.', uses: ['Arenas and suites', 'Theaters and cinemas', 'Arcades and attractions'], image: products, alt: 'Genesis 360 and BotaniMax product line' },
];

const testimonials = [
  { quote: "Using BAC Ag has been a huge success in our show pig operation! We went from having sow health issues to bringing in new sows and not having any issues! If you want a product that's going to help sanitize your barn before your customers come through, keeps your farrowing house clean and have healthier hogs while also making sure your pigs are ready to go to their new home, then using BAC Ag is the product for you!", name: 'Keaton Kitson', role: 'Owner, Kitson Show Pigs', image: farmer1 },
  { quote: 'I have two 1,200-head hog barns. I did a trial where I treated one barn with BAC Ag and not the other. The barn that was treated had 30% less deads, 30% less culls, and went to market 10 pounds heavier than the untreated barn.', name: 'Southwest Iowa Pig Farmer', role: 'Pork Producer', image: farmer2 },
  { quote: "I've been using BAC Ag since Dec. 2025 and it's been a game changer for us — not only taking away the terrible smell in the barns, but healthier lambs, no coughing or diarrhea that you see in heated barns. I highly recommend this product if you have livestock.", name: 'David Sark', role: 'Farmer', image: farmer3 },
  { quote: 'After BAC Ag was fogged into my pig barn, the pigs definitely seemed more active and were up, eating and drinking immediately. There also seemed to be less fly and mosquito issues in the summer in the barn where BAC Ag was used.', name: 'Iowa Pig Farmer', role: 'Pork Producer', image: farmer4 },
];

const posts: { title: string; date: string; image: ImageMetadata; alt: string }[] = [
  { title: 'How to Identify Sick Building Syndrome and Improve Indoor Air Quality in Your Building', date: 'March 27, 2026', image: sickBuilding, alt: 'Bright commercial building lobby with illustrated airborne germs' },
  { title: 'Reducing Microbial Risk to Improve Cannabis Crop Yield', date: 'January 26, 2026', image: cannabis, alt: 'Greenhouse comparison showing cannabis plants affected by mold' },
  { title: 'Are You Missing These 3 High-Risk Hotspots?', date: 'October 8, 2025', image: wrestling, alt: 'Two wrestlers in a gym with illustrated pathogens nearby' },
  { title: 'How Indoor Growing Facilities Can Protect Crops from Bacterial and Fungal Threats', date: 'September 10, 2025', image: greenhouse, alt: 'Rows of strawberries growing inside a greenhouse' },
];

---

<BaseLayout
  title="Secure Logic | Precision Misting. Automated Efficiency. 360-Degree Coverage."
  description="Secure Logic Genesis 360 automated dry-mist systems and BotaniMax botanical disinfectant for agriculture and mission-critical facilities."
>
  <header
    class="fixed left-0 right-0 top-0 z-50 transition-all duration-300"
    x-data="{ open: false, scrolled: false }"
    x-init="scrolled = window.scrollY > 8; window.addEventListener('scroll', () => scrolled = window.scrollY > 8, { passive: true })"
    x-bind:class="scrolled ? 'bg-white/92 shadow-[0_1px_0_hsl(214_32%_88%)] backdrop-blur-xl' : 'bg-canopy/82 backdrop-blur-md'"
  >
    <div class="container-page flex items-center gap-6 transition-all duration-300" x-bind:class="scrolled ? 'h-16' : 'h-20'">
      <a href="/" class="mr-auto flex items-center gap-3" aria-label="Secure Logic home">
        <Image
          src={logo}
          alt="Secure Logic logo"
          class="w-auto object-contain transition-all duration-300"
          x-bind:class="scrolled ? 'h-10' : 'h-12 brightness-0 invert'"
          widths={[120, 180, 240]}
          sizes="160px"
          priority
        />
      </a>
      <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary navigation">
        <a href="#platform" class="nav-link" x-bind:class="scrolled ? 'text-slate-700 hover:text-slate-950' : 'text-emerald-50/90 hover:text-white'">Genesis 360</a>
        <a href="#botanimax" class="nav-link" x-bind:class="scrolled ? 'text-slate-700 hover:text-slate-950' : 'text-emerald-50/90 hover:text-white'">BotaniMax</a>
        <a href="#applications" class="nav-link" x-bind:class="scrolled ? 'text-slate-700 hover:text-slate-950' : 'text-emerald-50/90 hover:text-white'">Applications</a>
        <a href="#resources" class="nav-link" x-bind:class="scrolled ? 'text-slate-700 hover:text-slate-950' : 'text-emerald-50/90 hover:text-white'">Resources</a>
      </nav>
      <a href="tel:18889974310" class="hidden text-sm font-medium transition xl:block" x-bind:class="scrolled ? 'text-slate-500' : 'text-emerald-50/70'">1-888-997-4310</a>
      <a href="#quote" class="hidden items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-semibold uppercase tracking-wide shadow-lift transition focus:outline-none focus:ring-4 lg:inline-flex" x-bind:class="scrolled ? 'bg-primary-600 text-white hover:bg-primary-700 focus:ring-primary-200' : 'bg-white/92 text-primary-700 hover:bg-white focus:ring-white/20'">Get a Quote</a>
      <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-md transition lg:hidden" x-bind:class="scrolled ? 'bg-slate-100 text-slate-800' : 'bg-white/10 text-white ring-1 ring-white/20'" x-on:click="open = !open" x-bind:aria-expanded="open.toString()" aria-label="Toggle navigation">
        <Menu class="h-5 w-5" x-show="!open" />
        <X class="h-5 w-5" x-show="open" x-cloak />
      </button>
    </div>
    <nav class="border-t border-slate-100 bg-white lg:hidden" x-show="open" x-cloak x-on:click="open = false" aria-label="Mobile navigation">
      <div class="container-page grid gap-1 py-5">
        <a href="#platform" class="mobile-link">Genesis 360</a>
        <a href="#botanimax" class="mobile-link">BotaniMax</a>
        <a href="#applications" class="mobile-link">Applications</a>
        <a href="#resources" class="mobile-link">Resources</a>
        <a href="#quote" class="button-primary mt-3 uppercase tracking-wide">Get a Quote</a>
      </div>
    </nav>
  </header>

  <main>
    <section
      class="relative isolate overflow-visible bg-canopy text-white"
    >
      <div class="absolute inset-0">
        <video
          class="absolute inset-0 h-full w-full object-cover opacity-95 transition-opacity duration-1000 ease-in-out"
          src={farmVideo}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-hidden="true"
          data-hero-slide="0"
        ></video>
        <video
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
          src={cannabisVideo}
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
          data-hero-slide="1"
        ></video>
        <video
          class="absolute bottom-0 left-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
          src={gymVideo}
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
          data-hero-slide="2"
        ></video>
        <video
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
          src={cowsVideo}
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
          data-hero-slide="3"
        ></video>
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(90deg,hsl(160_34%_14%)_0%,hsl(160_34%_14%/.96)_36%,hsl(160_34%_14%/.58)_68%,hsl(160_34%_14%/.18)_100%),linear-gradient(0deg,hsl(160_34%_14%/.72)_0%,hsl(160_34%_14%/.18)_42%,hsl(160_34%_14%/.04)_100%)]"></div>
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -bottom-24 left-0 h-96 w-3/4 rounded-full bg-botanical-300/10 blur-3xl motion-safe:animate-[mist_18s_ease-in-out_infinite_alternate]"></div>
        <div class="absolute -right-28 top-4 h-96 w-2/3 rounded-full bg-white/10 blur-3xl motion-safe:animate-[mist_24s_ease-in-out_infinite_alternate]"></div>
      </div>
      <div class="container-page relative grid min-h-[min(98vh,900px)] items-center py-20 lg:grid-cols-[1.02fr_.98fr]">
        <div class="relative z-10">
          <h1 class="max-w-[11ch] text-[clamp(4rem,10vw,8rem)] font-medium leading-[1] tracking-[-0.06em] text-white">
            <span class="typed-hero-shell block" aria-live="polite">
              <span class="typed-hero-reserve" aria-hidden="true">Disinfection</span>
              <span class="typed-hero-word" data-typed-hero-word>Disinfection</span>
            </span>
            Reimagined.
          </h1>
          <p class="mt-3 max-w-lg text-2xl font-medium leading-[1.6] tracking-[-0.01em] text-white/88 drop-shadow-[0_2px_12px_rgba(0,0,0,.42)] lg:mt-10">
            Automated dry mist protects air, surfaces, crops, and critical facilities.
          </p>
          <!--<div class="mt-8 flex flex-wrap gap-3">-->
          <!--  <a href="#platform" class="button-primary">Discover Genesis 360 <ArrowRight class="h-4 w-4" /></a>-->
          <!--  <a href="#quote" class="button-dark">Get a Quote</a>-->
          <!--</div>-->
          <div class="mt-11 flex max-w-xl flex-wrap gap-x-9 gap-y-5 border-t border-white/15 pt-6">
            <div><b class="block text-2xl font-semibold text-white">&lt;10 μm</b><span class="text-sm text-emerald-50/65">dry-mist droplet size</span></div>
            <div><b class="block text-2xl font-semibold text-white">360°</b><span class="text-sm text-emerald-50/65">air and surface coverage</span></div>
            <div><b class="block text-2xl font-semibold text-white">Automated</b><span class="text-sm text-emerald-50/65">programmable cycles</span></div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 right-6 z-10 hidden w-[min(25rem,calc(100vw-3rem))] rounded-lg bg-canopy p-5 ring-1 ring-white/20 backdrop-blur-md md:block lg:right-35">
        <div class="flex items-center gap-3">
          <span class="h-1 w-10 rounded-full bg-botanical-300"></span>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-botanical-200" data-hero-label>Agriculture</p>
        </div>
        <h2 class="mt-4 text-xl font-semibold text-white" data-hero-title>Crop fields and greenhouses</h2>
        <p class="mt-2 text-sm font-medium leading-6 text-white/82" data-hero-copy>Dry mist reaches canopy, equipment, and air zones without soaking plants or disrupting production.</p>
        <div class="mt-5 flex gap-2" aria-label="Hero applications">
          <button type="button" class="h-2.5 w-8 rounded-full bg-botanical-300 transition-all" data-hero-dot="0" aria-label="Show agriculture"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/35 transition-all hover:bg-white/60" data-hero-dot="1" aria-label="Show controlled environments"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/35 transition-all hover:bg-white/60" data-hero-dot="2" aria-label="Show built environments"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/35 transition-all hover:bg-white/60" data-hero-dot="3" aria-label="Show dairy barn airspace"></button>
        </div>
      </div>
      <CurveDivider class="-bottom-px text-white" />
    </section>

    <section id="platform" class="relative overflow-hidden bg-white py-14 lg:py-28">
      <div class="pointer-events-none absolute inset-0 max-lg:opacity-55" aria-hidden="true">
        <div class="absolute -bottom-0 -left-[5%] h-[90%] w-[68%] bg-[radial-gradient(ellipse_at_center,hsl(211_86%_84%/.45)_0%,hsl(160_44%_82%/.32)_44%,transparent_70%)]"></div>
        <div class="absolute -right-[16%] -top-[15%] h-[90%] w-[52%] bg-[radial-gradient(ellipse_at_center,hsl(104_48%_85%/.42)_0%,hsl(104_48%_88%/.18)_48%,transparent_72%)] max-lg:-bottom-[6%] max-lg:top-auto"></div>
      </div>
      <div class="container-page relative grid items-center gap-12 lg:grid-cols-[.95fr_1.05fr]">
        <div class="reveal relative pb-10 max-lg:order-2 max-lg:pb-0" x-data x-intersect.once="$el.classList.add('is-visible')">
          <div
            class="reveal overflow-hidden rounded-lg bg-slate-100 shadow-lift ring-1 ring-slate-900/5"
            x-data="{
              update() {
                const rect = $el.getBoundingClientRect();
                const progress = Math.min(1, Math.max(0, (window.innerHeight - rect.top) / (window.innerHeight + rect.height)));
                $refs.image.style.transform = `scale(${1.04 + progress * 0.12})`;
              }
            }"
            x-init="update(); window.addEventListener('scroll', () => requestAnimationFrame(() => update()), { passive: true }); window.addEventListener('resize', () => requestAnimationFrame(() => update()), { passive: true })"
          >
            <Image x-ref="image" src={products} alt="Genesis 360 and BotaniMax product line" class="w-full object-cover transition-transform duration-200" style="transform: scale(1.04);" widths={[640, 960, 1280]} sizes="(min-width: 1024px) 46vw, 100vw" />
          </div>
          <!--<div class="absolute bottom-0 right-0 w-[46%] overflow-hidden rounded-lg bg-slate-900 shadow-deep ring-4 ring-white max-sm:hidden">-->
          <!--  <video class="aspect-video w-full object-cover" autoplay muted loop playsinline preload="metadata">-->
          <!--    <source src="/videos/genesis-nozzles.mp4" type="video/mp4" />-->
          <!--  </video>-->
          <!--</div>-->
        </div>
        <div class="reveal" x-data x-intersect.once="$el.classList.add('is-visible')">
          <p class="eyebrow">Precision-Engineered Environmental Systems</p>
          <h2 class="section-title mt-4">The Genesis 360 Platform</h2>
          <p class="section-copy mt-5">
            Genesis 360 is an intelligent, automated misting platform engineered to provide true 360-degree coverage in every environment. Sub-10 micron dry-mist droplets distribute uniform coverage throughout air and surface zones, wrapping around, under, and behind objects.
          </p>
          <div class="mt-8 divide-y divide-slate-200 border-y border-slate-200">
            {[
              ['Sub-10 micron dry mist', 'hangs in air, no wetting', Droplets],
              ['Programmable automation', 'scheduled, repeatable cycles', Cpu],
              ['Whole-room coverage', 'around, under, behind objects', Sparkles],
              ['Botanical chemistry', 'BotaniMax plant-based disinfectant', Leaf],
            ].map(([title, copy, Icon]) => (
              <div class="flex items-center gap-4 py-4">
                <Icon class="h-6 w-6 shrink-0 text-primary-600" />
                <p><b class="font-semibold text-slate-900">{title}</b> <span class="text-slate-500">- {copy}</span></p>
              </div>
            ))}
          </div>
          <a href="#quote" class="group mt-7 inline-flex items-center gap-2 border-b border-primary-700 pb-1 text-sm font-semibold text-primary-700">
            Explore the full platform <ArrowRight class="h-4 w-4 transition group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-gradient-to-b from-white to-slate-100 py-14 lg:py-28">
      <div class="particle-field particle-field-light" aria-hidden="true">
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
      </div>
      <div class="container-page relative">
        <div class="reveal mx-auto max-w-3xl text-center" x-data x-intersect.once="$el.classList.add('is-visible')">
          <p class="eyebrow">The Cost of Inaction</p>
          <h2 class="section-title mx-auto mt-4">What you can't see is costing you.</h2>
          <p class="section-copy mx-auto mt-5 text-left">
            Airborne pathogens and biofilm move faster than wipes and hand-sprayers can. In agriculture, the losses are measured in billions and in yield you never harvest.
          </p>
        </div>
        <div class="mt-12 grid gap-5 max-md:mx-auto max-md:max-w-sm md:grid-cols-2 xl:grid-cols-4">
          {[
            ['$40B', 'In U.S. crop losses to pests and plant disease every year.', 'Source: USDA'],
            ['$20B+', 'Lost annually by U.S. livestock industries to disease.', 'Source: AVMA'],
            ['58M', 'Birds culled in the recent U.S. avian influenza outbreak.', 'Source: USDA ERS'],
            ['80%', 'Of recirculated air in animal housing and grow rooms can carry microbial contaminants.', 'Source: AEM, 2023'],
          ].map(([value, copy, source], index) => (
            <article class="reveal rounded-lg border-t-4 border-primary-500 bg-white/88 p-6 shadow-lift ring-1 ring-slate-900/5 backdrop-blur-sm" style={`transition-delay: ${index * 90}ms`} x-data x-intersect.once="$el.classList.add('is-visible')">
              <b class="block text-center text-5xl font-semibold leading-none tracking-normal text-primary-600 lg:text-6xl" data-stat-value={value}>{value}</b>
              <p class="mt-4 text-sm font-medium leading-6 text-slate-800">{copy}</p>
              <p class="mt-3 text-xs uppercase tracking-[0.14em] text-slate-500">{source}</p>
            </article>
          ))}
        </div>
        <div class="reveal mt-8 flex flex-wrap items-center gap-5 border-t border-slate-200 pt-7" x-data x-intersect.once="$el.classList.add('is-visible')">
          <span class="h-1 w-10 rounded-full bg-botanical-500"></span>
          <p class="font-semibold leading-7 text-slate-800">Genesis 360 replaces labor-intensive, inconsistent disinfection with automated, measurable coverage of the air and every surface.</p>
        </div>
      </div>
    </section>

    <section id="agriculture" class="relative overflow-hidden bg-canopy py-16 text-white lg:py-36">
      <CurveDivider class="top-0 rotate-180 text-slate-100" />
      <div class="container-page relative pt-8">
        <div class="reveal" x-data x-intersect.once="$el.classList.add('is-visible')">
          <p class="eyebrow text-botanical-300">Agriculture First</p>
          <h2 class="section-title mt-4 text-white">Reach every corner. Protect every acre.</h2>
          <p class="mt-5 max-w-3xl text-base leading-8 text-emerald-50/70">
            AgGriGuard Mist and InRoom Mist disperse BotaniMax into the air and across every exposed surface with touch-free, full-coverage disinfection for crops, canopy, and livestock.
          </p>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-[1.05fr_.95fr]">
          <a href="#applications" class="image-card reveal min-h-[520px]" x-data x-intersect.once="$el.classList.add('is-visible')" x-on:click.prevent="$dispatch('select-app', { index: 0 }); document.querySelector('#applications').scrollIntoView({ behavior: 'smooth' })">
            <Image src={greenhouse} alt="Greenhouse crop rows with strawberries" class="image-card-img" widths={[640, 960, 1280]} sizes="(min-width: 1024px) 50vw, 100vw" />
            <div class="image-card-copy">
              <h3>Crop fields and greenhouses</h3>
              <p>Protect crops from soilborne fungi, bacterial blight, and viruses without wetting foliage, media, or equipment.</p>
              <span>See deployments <ArrowRight class="h-4 w-4" /></span>
            </div>
          </a>
          <div class="grid gap-6">
            <a href="#applications" class="image-card reveal min-h-[250px]" style="transition-delay: 90ms" x-data x-intersect.once="$el.classList.add('is-visible')" x-on:click.prevent="$dispatch('select-app', { index: 0 }); document.querySelector('#applications').scrollIntoView({ behavior: 'smooth' })">
              <Image src={cannabis} alt="Indoor cannabis cultivation facility" class="image-card-img" widths={[520, 760, 960]} sizes="(min-width: 1024px) 45vw, 100vw" />
              <div class="image-card-copy">
                <h3>Controlled grow rooms</h3>
                <p>Automated treatment where humidity, airflow, and dense canopy growth create microbial pressure.</p>
                <span>See deployments <ArrowRight class="h-4 w-4" /></span>
              </div>
            </a>
            <div class="reveal rounded-lg bg-canopy-light p-7 shadow-lift ring-1 ring-white/10" style="transition-delay: 160ms" x-data x-intersect.once="$el.classList.add('is-visible')">
              <Cpu class="h-8 w-8 text-botanical-300" />
              <h3 class="mt-5 text-2xl font-semibold text-white">360HVAC Mist for ag facilities</h3>
              <p class="mt-3 text-sm leading-6 text-emerald-50/70">Infuses air-handling systems with ultra-fine BotaniMax mist, keeping coils, ducts, and vents clear of the biofilm that spreads facility-wide.</p>
              <a href="#applications" class="mt-5 inline-flex items-center gap-2 border-b border-white/40 pb-1 text-sm font-semibold text-white">See deployments <ArrowRight class="h-4 w-4" /></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="applications"
      class="bg-gradient-to-b from-slate-100 to-white py-14 lg:py-28"
    >
      <div class="container-page">
        <div class="reveal max-w-3xl" x-data x-intersect.once="$el.classList.add('is-visible')">
          <div>
            <p class="eyebrow">Applications</p>
            <h2 class="section-title mt-4">Applications That Demand Precision</h2>
            <p class="section-copy mt-5">Genesis 360 is designed for flexibility and scalability across industries where hygiene, safety, and environmental quality are mission-critical.</p>
          </div>
        </div>
